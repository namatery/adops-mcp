# adops-mcp configuration. Copy to `.env` to override defaults.
# The server runs fully against the in-memory MOCK backend with NO .env at all —
# this file only matters when you want to point at a live Taboola account.

# Which backend the server talks to: "mock" (default) or "taboola".
BACKEND=mock

# Where the JSONL audit log is written (every planned + executed action).
# Defaults to ./audit_log.jsonl in the working directory.
# AUDIT_LOG_PATH=./audit_log.jsonl

# --- Live Taboola Backstage credentials (only needed when BACKEND=taboola) ---
# Issued by your Taboola account manager. See the README "switch to live" section.
# TABOOLA_CLIENT_ID=your-client-id
# TABOOLA_CLIENT_SECRET=your-client-secret
# Optional: pin a specific account_id (e.g. "advertiser-1"). If unset, the server
# resolves the first account from /users/current/allowed-accounts.
# TABOOLA_ACCOUNT_ID=
